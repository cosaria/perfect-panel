{
  "name": "perfect-panel",
  "version": "1.6.3",
  "private": true,
  "homepage": "https://github.com/cosaria/perfect-panel",
  "bugs": {
    "url": "https://github.com/cosaria/perfect-panel/issues/new"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cosaria/perfect-panel.git"
  },
  "license": "GPL-3.0",
  "scripts": {
    "build": "cd web && bun run build",
    "clean": "cd web && bun run clean",
    "dev:admin": "cd web && bun run dev:admin",
    "dev:user": "cd web && bun run dev:user",
    "format": "cd web && bun run format",
    "lint": "cd web && bun run lint",
    "locale": "cd web && bun run locale",
    "openapi:spec": "cd server && go run . openapi -o ../docs/openapi",
    "openapi:client": "cd web && bun run openapi:client",
    "openapi:lint": "cd web && bunx redocly lint --config ../redocly.yaml ../docs/openapi/*.json",
    "openapi": "bun run openapi:spec && bun run openapi:lint && bun run openapi:client && bun run format",
    "typecheck": "cd web && bun run typecheck",
    "update:deps": "cd web && bun run update:deps",
    "update:shadcn": "cd web && bun run update:shadcn"
  },
  "packageManager": "bun@1.3.0",
  "engines": {
    "node": ">=20"
  }
}
