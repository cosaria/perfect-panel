    "@netlify/plugin-nextjs": "^5.12.1",
    "@redocly/cli": "^2.25.4",
    "@workspace/commitlint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "autoprefixer": "^10.4.21",
    "commitlint": "^19.6.1",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^3.4.17",
