    "@iconify-json/uil": "^1.2.3",
    "@iconify/react": "^5.2.0",
    "@lottiefiles/dotlottie-react": "^0.15.1",
    "@monaco-editor/react": "^4.7.0",
    "@noble/curves": "^2.0.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
