{
  "name": "perfect-panel",
  "version": "1.6.3",
  "private": true,
  "homepage": "https://github.com/cosaria/perfect-panel",
  "bugs": {
    "url": "https://github.com/cosaria/perfect-panel/issues/new"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cosaria/perfect-panel.git"
  },
  "license": "GPL-3.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "clean": "./scripts/clean.sh",
    "dev:admin": "turbo run dev --filter=ppanel-admin-web",
    "dev:user": "turbo run dev --filter=ppanel-user-web",
    "format": "biome format --write .",
    "lint": "turbo run lint",
    "locale": "turbo run locale && bun run format",
    "openapi:spec": "cd server && go run . openapi -o ../docs/openapi",
    "openapi:client": "turbo run openapi",
    "openapi:lint": "redocly lint docs/openapi/*.json",
    "openapi": "bun run openapi:spec && bun run openapi:lint && bun run openapi:client && bun run format",
    "typecheck": "turbo run check-types",
    "update:deps": "./scripts/update-deps.sh",
    "update:shadcn": "./scripts/update-shadcn-ui.sh && bun run format"
  },
  "commitlint": {
    "extends": [
      "@workspace/commitlint-config"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
