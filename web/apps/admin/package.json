{
  "name": "ppanel-admin-web",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check-types": "tsc --noEmit",
    "dev": "vite",
    "lint": "biome check .",
    "locale": "lobe-i18n --with-md",
    "openapi": "openapi-ts -f openapi-ts.config.ts && openapi-ts -f openapi-ts-common.config.ts && openapi-ts -f openapi-ts-user.config.ts",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "start": "bun run preview"
  },
  "dependencies": {
    "@lottiefiles/dotlottie-react": "^0.15.1",
    "@noble/curves": "^2.0.1",
    "@noble/ed25519": "^3.0.0",
    "@tanstack/react-query": "^5.85.5",
    "@tanstack/react-query-next-experimental": "^5.85.5",
    "@workspace/ui": "workspace:*",
    "ahooks": "^3.9.4",
    "axios": "^1.11.0",
    "js-yaml": "^4.1.0",
    "mlkem-wasm": "^0.0.6",
    "nanoid": "^5.1.5",
    "next": "16.2.2",
    "next-intl": "^4.8.4",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.8.16",
    "radash": "^12.1.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router-dom": "^7.14.0",
    "react-turnstile": "^1.1.4",
    "universal-cookie": "^8.0.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/rtl-detect": "^1.0.3",
    "@workspace/typescript-config": "workspace:*",
    "vite": "^7.1.10",
    "typescript": "^5.9.2"
  },
  "i18n": {
    "entry": "./locales/en-US",
    "entryLocale": "en-US",
    "output": "./locales",
    "saveImmediately": true,
    "concurrency": 10,
    "outputLocales": [
      "en-US",
      "zh-CN"
    ],
    "modelName": "gpt-4o-mini",
    "experimental": {
      "jsonMode": true
    },
    "markdown": {
      "entry": [
        "./README.md"
      ],
      "outputLocales": [
        "zh-CN"
      ]
    }
  }
}
