{
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": ".",
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "@/*": ["./*"],
      "@workspace/ui/*": ["../../packages/ui/src/*"]
    },
    "plugins": []
  },
  "exclude": ["node_modules"],
  "extends": "@workspace/typescript-config/react-library.json",
  "include": ["src/**/*.ts", "src/**/*.tsx", "**/*.ts", "**/*.tsx", "services/**/typings.d.ts"]
}
