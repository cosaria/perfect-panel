{
	"compilerOptions": {
		"baseUrl": ".",
		"esModuleInterop": true,
		"jsx": "react-jsx",
		"lib": ["DOM", "DOM.Iterable", "ES2022"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"noEmit": true,
		"paths": {
			"~/*": ["./src/*"]
		},
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"strict": true,
		"target": "ES2022",
		"types": ["node", "vite/client"]
	},
	"include": ["src", "app.config.ts", "vite.config.ts"],
	"exclude": ["dist", "node_modules"]
}
